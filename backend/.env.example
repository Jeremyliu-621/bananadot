# Copy to .env and fill in. .env is gitignored.

# Gemini / Nano Banana Pro — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Image model. Options as of 2026-04:
#   gemini-3-pro-image-preview      — Nano Banana Pro, best quality, slower
#   gemini-3.1-flash-image-preview  — Nano Banana 2 Flash, ~3× faster, slightly lower fidelity
#   nano-banana-pro-preview         — alias for gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Where to drop generated bundles on disk.
OUTPUT_DIR=./outputs
