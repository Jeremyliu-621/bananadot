# Copy to .env and fill in. .env is gitignored.

# OpenAI — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Image model. `gpt-image-2` (released 2026-04-21) is the reasoning-based
# successor to gpt-image-1. It accepts multiple reference images per call
# (which the consistency-anchor chain depends on) and supports far more
# flexible output sizes — any dimensions that are multiples of 16, up to
# 3:1 long:short edge ratio, 655k–8.3M total pixels. Pin the snapshot
# (gpt-image-2-2026-04-21) if you want output stability across API updates.
OPENAI_IMAGE_MODEL=gpt-image-2

# Where to drop generated bundles on disk.
OUTPUT_DIR=./outputs
